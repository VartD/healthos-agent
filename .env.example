# HealthOS — пример файла переменных окружения
# Скопируйте этот файл в .env и заполните значения

# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Общий ключ доступа бота к закрытому Backend API (минимум 32 случайных символа)
HEALTHOS_API_KEY=replace_with_a_long_random_value

# Часовой пояс MVP. В будущем должен храниться в профиле пользователя.
HEALTHOS_TIMEZONE=Asia/Yekaterinburg

# Пароль локальной PostgreSQL в Docker Compose
POSTGRES_PASSWORD=replace_with_a_long_random_value

# Необязательно: только для реального smoke-теста Telegram
# TELEGRAM_SMOKE_CHAT_ID=123456789
# TELEGRAM_SMOKE_USER_ID=123456789

# URL Backend API (для бота)
# Локальная разработка: http://127.0.0.1:8000
# Docker Compose: http://backend:8000
BACKEND_URL=http://127.0.0.1:8000

# URL базы данных
# PostgreSQL (production): postgresql+psycopg2://user:password@host:5432/dbname
# SQLite (разработка): sqlite:///./healthos.db
DATABASE_URL=postgresql+psycopg2://healthos:replace_password@localhost:5432/healthos

# --- Переменные для будущих функций (не реализованы) ---
# OPENAI_API_KEY=sk-...
# CLOUDFLARE_TUNNEL_TOKEN=...
